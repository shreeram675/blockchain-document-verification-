# Copy to server/.env for local development. Do not commit real secrets.
PORT=5000

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=docverify

# Blockchain (optional depending on your environment)
BLOCKCHAIN_RPC_URL=
CONTRACT_ADDRESS=
PRIVATE_KEY=

# Frontend (used for QR links)
FRONTEND_URL=http://localhost:5173

